HOUSECALL_PRO_API_KEY=replace-me
HOUSECALL_PRO_AUTH_SCHEME=auto
HOUSECALL_PRO_BASE_URL=https://api.housecallpro.com
HOUSECALL_PRO_CUSTOMERS_PATH=/customers
HOUSECALL_PRO_CUSTOMER_PATH=/customers/{customerId}
HOUSECALL_PRO_JOBS_PATH=/jobs
HOUSECALL_PRO_JOB_PATH=/jobs/{jobId}
HOUSECALL_PRO_ESTIMATES_PATH=/estimates
HOUSECALL_PRO_ESTIMATE_PATH=/estimates/{estimateId}
HOUSECALL_PRO_INVOICES_PATH=/invoices
HOUSECALL_PRO_INVOICE_PATH=/api/invoices/{invoiceId}
HOUSECALL_PRO_JOB_INVOICES_PATH=/jobs/{jobId}/invoices
HOUSECALL_PRO_LEADS_PATH=/leads
HOUSECALL_PRO_BEARER_TOKEN=

# --- Slack agent (Viktor-style assistant, Socket Mode) ---
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_APP_TOKEN=xapp-replace-me
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PORT=3000
SLACK_AGENT_HISTORY_MESSAGES=24
# Optional: path to custom estimator rules JSON (same schema as src/estimator/defaultRulesData.ts)
ESTIMATOR_RULES_PATH=

# --- MCP over HTTP (Railway / Fly.io / any Node host) — Streamable HTTP transport ---
# Start: npm run start:http  (after npm run build)
# MCP_HTTP_PATH=/mcp
# MCP_HTTP_HOST=0.0.0.0
# MCP_ALLOWED_HOSTS=your-app.up.railway.app
# MCP_HTTP_AUTH_TOKEN=long-random-secret
